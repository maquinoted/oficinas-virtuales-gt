        .logo { font-weight: 800; font-size: 1.3rem; color: var(--navy); display: flex; align-items: center; gap: 12px; text-transform: uppercase; }
        .logo-box { width: 35px; height: 35px; background: var(--accent); border-radius: 8px; }

        header { background: linear-gradient(rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.9)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80'); background-size: cover; background-position: center; color: white; padding: 120px 20px; text-align: center; }
        header h1 { font-size: 3.5rem; margin: 0; letter-spacing: -2px; line-height: 1.1; }
        header p { font-size: 1.25rem; color: #f1f5f9; max-width: 700px; margin: 25px auto; }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        section { padding: 30px 0; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
        
        .img-container { background: #e2e8f0; border-radius: 24px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15); aspect-ratio: 3 / 2; }
        .img-container img { width: 100%; height: 100%; object-fit: cover; }

        .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 40px 25px; margin-top: 70px; }
        .price-card { background: var(--white); padding: 50px 30px; border-radius: 24px; text-align: center; transition: 0.3s; border: 1px solid #e2e8f0; position: relative; display: flex; flex-direction: column; justify-content: space-between; }
        .price-card.featured { border: 2.5px solid var(--accent); z-index: 10; }
        .featured-tag { position: absolute; top: -18px; left: 50%; transform: translateX(-50%); background: var(--navy); color: white; padding: 8px 24px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
        
        .amount { font-size: 3rem; font-weight: 800; color: var(--navy); margin: 15px 0; }
        .amount span { font-size: 0.9rem; color: var(--slate); }

        .seo-section { background: var(--navy); color: white; padding: 80px 40px; border-radius: 32px; margin-top: 40px; }
        .seo-section h2 { color: #60a5fa; border-left: 4px solid #60a5fa; padding-left: 20px; text-align: left; margin-bottom: 20px; }

        .btn { display: inline-block; background: var(--accent); color: white; padding: 16px 30px; border-radius: 12px; text-decoration: none; font-weight: 700; transition: 0.3s; margin-top: 20px; text-align: center; }
        .btn:hover { background: #1e40af; transform: scale(1.02); }
        
        footer { background: var(--navy); color: #e2e8f0; padding: 60px 20px; text-align: center; margin-top: 50px; }
        .wa-float { position: fixed; bottom: 35px; right: 35px; background: var(--success); width: 65px; height: 65px; border-radius: 20px; display: flex; align-items: center; justify-content: center; color: white; z-index: 2000; box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

        /* FAQ STYLES */
        .faq-section { padding: 4rem 1rem; background: #f9f9f9; }
        .faq-grid { max-width: 900px; margin: 0 auto; }
        details { background: white; margin-bottom: 1rem; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        summary { padding: 1.2rem; cursor: pointer; font-weight: 700; color: #1a2b4b; list-style: none; position: relative; }
        summary::after { content: '+'; position: absolute; right: 20px; }
        details[open] summary::after { content: '-'; }
        .answer { padding: 0 1.2rem 1.2rem; color: #444; line-height: 1.6; }

        @media (max-width: 768px) { .grid-2 { grid-template-columns: 1fr; } h1 { font-size: 2.3rem !important; } }
    </style>

    <nav>
