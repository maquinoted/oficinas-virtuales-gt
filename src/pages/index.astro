---
// index.astro
import Layout from '../layouts/Layout.astro';

// Trasladamos los datos de Schema aquí para que el archivo sea más limpio
const schemaGraph = [
  {
    "@type": "WebPage",
    "@id": "https://www.oficinasvirtualesguatemala.com/#webpage",
    "url": "https://www.oficinasvirtualesguatemala.com/",
    "name": "Oficinas Virtuales en Guatemala | Dirección Fiscal y Comercial",
    "description": "Servicios de oficina virtual y domicilio fiscal actualizados para febrero 2026 en Guatemala.",
    "datePublished": "2024-01-01T08:00:00+00:00",
    "dateModified": "2026-02-13T12:00:00+00:00"
  },
  // ... (Aquí iría el resto de tu JSON de Schema)
];
---

<Layout 
    title="Oficinas Virtuales en Guatemala | Dirección Fiscal SAT y Comercial"
    description="Alquilamos Oficinas Virtuales en Guatemala. Obtenga su dirección fiscal para SAT e inscripción de sociedades en Zona Pradera desde Q150."
>
    <script type="application/ld+json" is:inline set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })} />

    <style is:inline>
        :root {
            --navy: #0f172a; --accent: #1d4ed8; --slate: #475569; 
            --light: #f8fafc; --white: #ffffff; --success: #15803d;
        }
        /* ... (Copia aquí todo el CSS de tu archivo original) */
    </style>

    <nav>
        <div class="logo"><div class="logo-box"></div>Oficinas virtuales</div>
    </nav>

    <header>
        <div class="container">
            <h1>Oficinas Virtuales en Guatemala</h1>
            <p>La solución líder en <strong>dirección fiscal</strong> y comercial para empresas que buscan cumplimiento legal total ante la SAT y prestigio corporativo.</p>
            <a href="https://wa.me/50223010800" class="btn">Cotice aquí</a>
        </div>
    </header>

    <main class="container">
        <section class="grid-2">
            <div>
                <h2>Inscripción de Sociedades y Domicilio Legal</h2>
                <p>Nuestra <strong>dirección comercial en Zona 10</strong> es el aliado estratégico para su <strong>inscripción de sociedades</strong>.</p>
                <a href="#planes" class="btn" style="background:var(--navy)">Ver Planes</a>
            </div>
            <div class="img-container">
                <img src="https://www.oficinasvirtualesguatemala.com/oficinas-virtuales-guatemala.jpg" alt="Oficinas en Zona 10" />
            </div>
        </section>

        </main>

    <footer>
        <p>Zona Pradera, Torre 2, oficina 1108, Ciudad de Guatemala | PBX 23010800</p>
    </footer>

    <script is:inline>
        document.getElementById("contact-form").addEventListener("submit", async (e) => {
            e.preventDefault();
            const btn = document.getElementById("submit-btn");
            btn.disabled = true;
            const data = new FormData(e.target);
            try {
                const res = await fetch("https://formspree.io/f/xdalgllg", { 
                    method: "POST", 
                    body: data, 
                    headers: { 'Accept': 'application/json' } 
                });
                if (res.ok) window.location.href = "/gracias";
            } catch (err) { alert("Error al enviar."); }
            btn.disabled = false;
        });
    </script>
</Layout>