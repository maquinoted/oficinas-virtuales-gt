    <script is:inline>
      const inicializarAudio = () => {
        const audio = document.getElementById('audio-virtual');
        if (audio) audio.currentTime = 0;
      };
      window.addEventListener('load', inicializarAudio);

      document.getElementById("contact-form").addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = document.getElementById("submit-btn");
        btn.disabled = true;
        const data = new FormData(e.target);
        try {
          const res = await fetch("https://formspree.io/f/xdalgllg", { method: "POST", body: data, headers: { 'Accept': 'application/json' } });
          if (res.ok) window.location.href = "/gracias";
        } catch (err) { alert("Error al enviar."); }
        btn.disabled = false;
      });
    </script>
