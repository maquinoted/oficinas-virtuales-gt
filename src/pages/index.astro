    <style is:inline>
        :root {
            --navy: #0f172a; --accent: #1d4ed8; --slate: #475569; 
            --light: #f8fafc; --white: #ffffff; --success: #15803d;
        }

        body { margin: 0; font-family: 'Inter', system-ui, sans-serif; background-color: var(--light); color: var(--navy); line-height: 1.6; }
