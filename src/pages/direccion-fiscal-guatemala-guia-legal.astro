---
import Layout from '../layouts/Layout.astro';

const title = "Guía Legal: Dirección Fiscal en Guatemala 2026 | Oficinas Virtuales";
const description = "Requisitos de la SAT para formalizar su empresa con oficina virtual.";
---

<Layout title={title} description={description}>
    <style is:inline>
        .container-formalizacion { width: 100%; padding: 4rem 1.5rem; background: white; }
        .content-wrapper { max-width: 1100px; margin: 0 auto; }
        .main-title { font-size: 3rem; font-weight: 900; text-align: center; margin-bottom: 3rem; color: #0f172a; }
        .text-teal { color: #0d9488; }
        .comparison-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 3rem; margin-bottom: 5rem; justify-items: center; }
        .tarjeta-visual { width: 400px; height: 230px; border-radius: 16px; padding: 2rem; position: relative; box-sizing: border-box; overflow: hidden; }
        .informal { background: #fff; border: 2px solid #f1f5f9; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        .profesional { background: #2d3136; color: white; box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
        .sello-informal { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-15deg); color: rgba(239, 68, 68, 0.1); font-size: 3.5rem; font-weight: 900; }
        .footer-content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 4rem; border-top: 1px solid #eee; padding-top: 4rem; }
        .form-card { background: #f8fafc; padding: 30px; border-radius: 20px; border: 1px solid #eee; }
        @media (max-width: 900px) { .comparison-grid, .footer-content-grid { grid-template-columns: 1fr; } .tarjeta-visual { width: 100%; max-width: 400px; } }
    </style>

    <div class="container-formalizacion">
        <main class="content-wrapper">
            <h1 class="main-title">Guía Legal de <span class="text-teal">Formalización SAT</span></h1>

            <section class="comparison-grid">
                <div class="tarjeta-visual informal">
                    <div class="sello-informal">INFORMAL</div>
                    <div style="position:relative; z-index:2;">
                        <h3 style="margin:0;">Consultores Profesionales SA</h3>
                        <p style="font-weight:bold; margin-top:10px;">Jorge Perez</p>
                        <p style="font-size:12px; margin-top:20px; color:#64748b;">📍 Dirección Residencial (No apta SAT)</p>
                    </div>
                </div>

                <div class="tarjeta-visual profesional">
                    <div style="position:relative; z-index:2;">
                        <h3 style="margin:0; color:#22d3ee;">Consultores Profesionales SA</h3>
                        <p style="font-weight:bold; margin-top:10px;">Jorge Perez</p>
                        <p style="font-size:12px; margin-top:20px;">📍 Zona Pradera, Torre 2 Oficina 1108</p>
                    </div>
                </div>
            </section>

            <div class="footer-content-grid">
                <article>
                    <h2>Requisitos Legales 2026</h2>
                    <p>Para habilitar su Factura Electrónica (FEL), la SAT exige un domicilio fiscal localizable. El contrato de subarrendamiento que proporcionamos cumple con todos los estándares legales.</p>
                </article>

                <aside class="form-card">
                    <h3>Inicia tu trámite</h3>
                    <form id="legal-form" style="display:flex; flex-direction:column; gap:12px;">
                        <input type="text" name="nombre" required placeholder="Nombre" style="padding:12px; border-radius:8px; border:1px solid #cbd5e1;">
                        <input type="tel" name="telefono" required placeholder="WhatsApp" style="padding:12px; border-radius:8px; border:1px solid #cbd5e1;">
                        <button type="submit" style="padding:12px; background:#0f172a; color:white; border-radius:8px; border:none; cursor:pointer;">Solicitar Asesoría</button>
                    </form>
                </aside>
            </div>
        </main>
    </div>

    <script is:inline>
        document.getElementById("legal-form").addEventListener("submit", async (e) => {
            e.preventDefault();
            const data = new FormData(e.target);
            await fetch("https://formspree.io/f/xdalgllg", { method: "POST", body: data, headers: { 'Accept': 'application/json' } });
            window.location.href = "/gracias";
        });
    </script>
</Layout>